
{
  "envId": "{{envId}}",
  "version": "2.0",
  "functionRoot": "functions",
  "functions": [
    {
      "name": "booking-system",
      "runtime": "Nodejs16.13",
      "timeout": 30,
      "memorySize": 256,
      "handler": "index.main",
      "installDependency": true
    }
  ],
  "framework": {
    "name": "booking-app",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "buildCommand": "echo 'no build'",
          "outputPath": ".",
          "cloudBasePath": "/",
          "routes": [
            {
              "path": "/api/*",
              "function": "booking-system"
            }
          ]
        }
      }
    }
  }
}
