# 微信配置环境变量

# 微信公众号配置
WECHAT_APPID=你的微信 AppID
WECHAT_SECRET=你的微信 AppSecret

# 腾讯云配置
TENCENT_ENV_ID=suhouyong2026-5gq178it64857137

# 服务器配置
PORT=3000
NODE_ENV=development

# 微信回调地址（生产环境修改为你的域名）
BASE_URL=http://localhost:3000

# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的微信 AppID 和 AppSecret
# 3. 生产环境 BASE_URL 改为你的实际域名
# 4. 不要将 .env 文件提交到 Git
